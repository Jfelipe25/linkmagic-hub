{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5"
    }
  },
  "routes": [
    {
      "src": "/u/(?<slug>[^/]+)",
      "dest": "/api/u/[slug]?slug=$slug"
    },
    {
      "src": "/card/(?<slug>[^/]+)",
      "dest": "/api/card/[slug]?slug=$slug"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
