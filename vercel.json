{
  "rewrites": [
    {
      "source": "/u/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(bot|crawl|slurp|spider|whatsapp|facebook|twitter|telegram|linkedin|slack|discord).*"
        }
      ],
      "destination": "/api/u/:slug"
    },
    { "source": "/card/:slug", "destination": "/api/card/:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
